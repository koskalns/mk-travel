<style>
	:root {
		--bg-main: #f8eecf;
		--bg-accent: #f3e0b6;
		--ink: #2a1d0e;
		--muted: #5c4c35;
		--card: rgba(255, 247, 224, 0.92);
		--retro-frame: #6f4c20;
		--retro-frame-dark: #4b3316;
		--pixel-aqua: #d8bf8a;
		--pixel-peach: #e0b15c;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: "Nunito", sans-serif;
		color: var(--ink);
		background:
			linear-gradient(rgba(42, 29, 14, 0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(42, 29, 14, 0.05) 1px, transparent 1px),
			radial-gradient(circle at 82% 14%, rgba(211, 168, 84, 0.45), transparent 35%),
			linear-gradient(160deg, var(--bg-main), var(--bg-accent));
		background-size:
			12px 12px,
			12px 12px,
			auto;
	}

	.app-shell {
		max-width: 1380px;
		margin: 0 auto;
		padding: 1.2rem 1rem 2rem;
	}

	.intro {
		margin-bottom: 1.4rem;
	}

	h1 {
		font-family: "Pixelify Sans", sans-serif;
		font-size: clamp(1.8rem, 4vw, 2.7rem);
		line-height: 1.2;
		margin: 0.2rem 0 0;
		text-transform: none;
		letter-spacing: 0.02em;
		color: var(--ink);
		text-shadow: 2px 2px 0 #e8cb8d;
	}

	.content-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.9rem;
	}

	.globe-card {
		background: var(--card);
		border: 3px solid var(--retro-frame);
		border-radius: 8px;
		box-shadow:
			6px 6px 0 var(--retro-frame-dark),
			inset 0 0 0 2px rgba(255, 255, 255, 0.45);
	}

	.globe-card {
		padding: 0.5rem;
		position: relative;
		overflow: hidden;
	}

	#mapViz {
		height: 76vh;
		min-height: 560px;
		width: 100%;
		border: 3px solid var(--pixel-aqua);
		border-radius: 6px;
		background: #f4e1b9;
		overflow: hidden;
	}

	:global(.leaflet-tile) {
		image-rendering: pixelated;
		filter: sepia(0.14) saturate(0.9) contrast(1.03) brightness(0.99);
	}

	:global(.leaflet-marker-icon) {
		image-rendering: pixelated;
		filter: drop-shadow(1px 2px 0 rgba(111, 118, 115, 0.45));
	}

	:global(.leaflet-container) {
		background: #f4e1b9;
	}

	:global(.leaflet-popup-content-wrapper),
	:global(.leaflet-popup-tip) {
		background: #fff7e0;
		border: 2px solid #6f4c20;
		color: #2a1d0e;
		box-shadow: 3px 3px 0 #4b3316;
		border-radius: 6px;
	}

	:global(.leaflet-popup-content) {
		font-family: "Nunito", sans-serif;
		font-size: 1.75rem;
		line-height: 1.35;
	}

	:global(.leaflet-control-zoom a) {
		background: var(--pixel-peach);
		color: #2a1d0e;
		border-bottom: 2px solid #6f4c20;
		font-family: "Pixelify Sans", sans-serif;
		font-size: 1rem;
		font-weight: 600;
	}

	:global(.leaflet-control-zoom a:hover) {
		background: #efc46f;
	}

	:global(.leaflet-control-attribution) {
		background: rgba(255, 247, 224, 0.92);
		color: #5c4c35;
		font-family: "Nunito", sans-serif;
		font-size: 0.8rem;
	}

	:global(.leaflet-control-attribution a) {
		color: #6f4c20;
	}

	@media (max-width: 900px) {
		.content-grid {
			grid-template-columns: 1fr;
		}

		#mapViz {
			height: 62vh;
			min-height: 420px;
		}

	}
</style>
