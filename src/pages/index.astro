					lng: 116.4074,
					days: 0,
					spend: 0,
					note: "Add trip details.",
				},
				{
					city: "Tbilisi",
					country: "Georgia",
					lat: 41.7151,
					lng: 44.8271,
					days: 0,
					spend: 0,
					note: "Add trip details.",
				},
			];

			const titleEl = document.getElementById("tripTitle");
			const summaryEl = document.getElementById("tripSummary");
			const daysEl = document.getElementById("tripDays");
			const spendEl = document.getElementById("tripSpend");
			const momentEl = document.getElementById("tripMoment");
			const mapEl = document.getElementById("mapViz");

			const setTripInfo = (trip) => {
				titleEl.textContent = `${trip.city}, ${trip.country}`;
				summaryEl.textContent = `A ${trip.days}-day stop with memories worth repeating.`;
				daysEl.textContent = `${trip.days} days`;
				spendEl.textContent = new Intl.NumberFormat("en-US", {
					style: "currency",
					currency: "EUR",
					maximumFractionDigits: 0,
				}).format(trip.spend);
				momentEl.textContent = trip.note;
			};

			if (!mapEl) {
				throw new Error("Map mount element not found.");
			}

			try {
				const pigPinIcon = L.icon({
					iconUrl: "/pig-pin.svg",
					iconSize: [34, 34],
					iconAnchor: [17, 30],
					popupAnchor: [0, -24],
				});

				const map = L.map(mapEl, {
					worldCopyJump: true,
					minZoom: 2,
					maxZoom: 8,
					zoomSnap: 0.25,
					zoomDelta: 0.75,
					wheelPxPerZoomLevel: 28,
				});

				L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
					attribution:
						'&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; CARTO',
					subdomains: "abcd",
				}).addTo(map);

				const bounds = [];
				for (const trip of trips) {
					const marker = L.marker([trip.lat, trip.lng], {
						icon: pigPinIcon,
					}).addTo(map);

					marker.bindPopup(
						`<b>${trip.city}, ${trip.country}</b><br/>Days: ${trip.days}<br/>Spend: ${new Intl.NumberFormat("en-US", {
							style: "currency",
							currency: "EUR",
							maximumFractionDigits: 0,
						}).format(trip.spend)}`,
					);

					marker.on("click", () => setTripInfo(trip));
					bounds.push([trip.lat, trip.lng]);
				}

				if (bounds.length > 0) {
					map.fitBounds(bounds, {
						padding: [45, 45],
						maxZoom: 3.75,
					});
				}

				window.addEventListener("resize", () => map.invalidateSize());
			} catch (error) {
				console.error("Failed to initialize map", error);
				mapEl.innerHTML =
					"<p style='padding:1rem;color:#3f4e3e'>Could not load map. Please refresh or check your network connection.</p>";
			}
		</script>
