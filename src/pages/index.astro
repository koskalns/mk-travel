<style>
	:root {
		--bg-main: #f8eecf;
		--ink: #2a1d0e;
		--muted: #5c4c35;
		--card: rgba(255, 247, 224, 0.92);
		--border: #a68955;
		--retro-red: #cb2d2d;
		--retro-frame: #6f4c20;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		font-family: "VT323", monospace;
		color: var(--ink);
		background:
			linear-gradient(rgba(42, 29, 14, 0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(42, 29, 14, 0.05) 1px, transparent 1px),
			radial-gradient(circle at 82% 14%, rgba(211, 168, 84, 0.45), transparent 35%),
			var(--bg-main);
		background-size:
			12px 12px,
			12px 12px,
			auto;
	}

	.app-shell {
		max-width: 1380px;
		margin: 0 auto;
		padding: 1.2rem 1rem 2rem;
	}

	.intro {
		margin-bottom: 1.4rem;
	}

	h1 {
		font-family: "Press Start 2P", cursive;
		font-size: clamp(1.1rem, 3vw, 2rem);
		line-height: 1.4;
		margin: 0.2rem 0 0;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--ink);
		text-shadow: 2px 2px 0 #e8cb8d;
	}

	.content-grid {
		display: grid;
		grid-template-columns: 3.4fr 1fr;
		gap: 0.9rem;
	}

	.globe-card,
	.info-card {
		background: var(--card);
		border: 3px solid var(--retro-frame);
		border-radius: 10px;
		box-shadow:
			6px 6px 0 rgba(42, 29, 14, 0.3),
			inset 0 0 0 2px rgba(255, 255, 255, 0.45);
	}

	.globe-card {
		padding: 0.5rem;
		position: relative;
		overflow: hidden;
	}

	#mapViz {
		height: 76vh;
		min-height: 560px;
		width: 100%;
	}

	.info-card {
		padding: 1.2rem 1rem;
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		font-size: 1.5rem;
	}

	h2 {
		font-family: "Press Start 2P", cursive;
		font-size: 1rem;
		line-height: 1.6;
		margin: 0;
	}

	#tripSummary {
		margin: 0.65rem 0 1.25rem;
		color: var(--muted);
	}

	.stats {
		margin: 0;
		display: grid;
		gap: 0.85rem;
	}

	.stats div {
		padding: 0.8rem;
		border-radius: 8px;
		background: rgba(255, 251, 240, 0.78);
		border: 2px dashed rgba(92, 76, 53, 0.6);
	}

	dt {
		font-size: 0.95rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-weight: 400;
		color: var(--muted);
	}

	dd {
		margin: 0.25rem 0 0;
		font-size: 1.35rem;
		font-weight: 400;
	}

	@media (max-width: 900px) {
		.content-grid {
			grid-template-columns: 1fr;
		}

		#mapViz {
			height: 62vh;
			min-height: 420px;
		}

		.info-card {
			padding: 1rem;
		}
	}
</style>
