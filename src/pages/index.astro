					lat: 28.1722,
					lng: 109.6295,
					days: 0,
					spend: 0,
					note: "Add trip details.",
				},
				{
					city: "Zhangjiajie",
					country: "China",
					lat: 29.1171,
					lng: 110.4792,
					days: 0,
					spend: 0,
					note: "Add trip details.",
				},
				{
					city: "Beijing",
					country: "China",
					lat: 39.9042,
					lng: 116.4074,
					days: 0,
					spend: 0,
					note: "Add trip details.",
				},
				{
					city: "Tbilisi",
					country: "Georgia",
					lat: 41.7151,
					lng: 44.8271,
					days: 0,
					spend: 0,
					note: "Add trip details.",
				},
				{
					city: "Warsaw",
					country: "Poland",
					lat: 52.2297,
					lng: 21.0122,
					days: 0,
					spend: 0,
					note: "Add trip details.",
				},
			];
			const mapEl = document.getElementById("mapViz");

			if (!mapEl) {
				throw new Error("Map mount element not found.");
			}

			try {
				const pigPinIcon = L.icon({
					iconUrl: "/pig-pin.svg",
					iconSize: [34, 34],
					iconAnchor: [17, 30],
					popupAnchor: [0, -24],
				});

				const map = L.map(mapEl, {
					worldCopyJump: true,
					minZoom: 2,
					maxZoom: 8,
					zoomSnap: 0.25,
					zoomDelta: 0.75,
					wheelPxPerZoomLevel: 28,
				});

				L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
					attribution:
						'&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; CARTO',
					subdomains: "abcd",
				}).addTo(map);

				const normalizeCountry = (value) =>
					value
						.toLowerCase()
						.normalize("NFD")
						.replace(/[\u0300-\u036f]/g, "")
						.replace(/[^a-z\s]/g, "")
						.replace(/\s+/g, " ")
						.trim();

				const countryAliases = {
					england: "united kingdom",
				};

				const territoryDenylist = new Set([
					"french guiana",
					"guiana",
					"guyane",
					"guyane francaise",
					"guyana",
					"guadeloupe",
					"martinique",
					"reunion",
					"mayotte",
					"falkland islands",
					"falkland",
					"malvinas",
					"curacao",
					"sint maarten",
					"aruba",
					"bonaire",
					"eustatius",
					"saba",
					"saint barthelemy",
					"saint martin",
					"st barthelemy",
					"st martin",
					"turks and caicos",
					"british virgin islands",
					"virgin islands",
					"puerto rico",
					"us virgin islands",
					"us virgin",
					"greenland",
					"aland islands",
					"faroe islands",
					"new caledonia",
					"french polynesia",
					"samoa",
					"american samoa",
					"guam",
					"northern mariana",
					"hong kong",
					"macao",
					"macau",
				]);

				const pinnedCountries = new Set(
					trips.map((trip) => {
						const normalized = normalizeCountry(trip.country);
						return countryAliases[normalized] ?? normalized;
					}),
				);

				map.createPane("countryHighlight");
				map.getPane("countryHighlight").style.zIndex = "360";
				map.getPane("countryHighlight").style.pointerEvents = "none";

				const countryGeoJsonUrl =
					"https://raw.githubusercontent.com/datasets/geo-countries/master/data/countries.geojson";
				const response = await fetch(countryGeoJsonUrl);
				if (response.ok) {
					const world = await response.json();
					L.geoJSON(world, {
						pane: "countryHighlight",
						style: (feature) => {
							const props = feature?.properties ?? {};
							
							// First check: if the place's actual NAME is a territory, always exclude it
							const featureName = normalizeCountry(props.NAME || props.name || "");
							if (territoryDenylist.has(featureName)) {
								return {
									color: "transparent",
									weight: 0,
									fillColor: "transparent",
									fillOpacity: 0,
								};
							}
							
							// Only highlight if it's an actual pinned country
							const isPinnedCountry = pinnedCountries.has(featureName);
							return {
								color: isPinnedCountry ? "#f4bfd5" : "transparent",
								weight: isPinnedCountry ? 1 : 0,
								fillColor: isPinnedCountry ? "#f8d5e5" : "transparent",
								fillOpacity: isPinnedCountry ? 0.35 : 0,
							};
						},
					}).addTo(map);
				}

				const bounds = [];
				for (const trip of trips) {
					const marker = L.marker([trip.lat, trip.lng], {
						icon: pigPinIcon,
					}).addTo(map);

					marker.bindPopup(
						`<b>${trip.city}, ${trip.country}</b><br/>Days: ${trip.days}<br/>Spend: ${new Intl.NumberFormat("en-US", {
							style: "currency",
							currency: "EUR",
							maximumFractionDigits: 0,
						}).format(trip.spend)}`,
					);

					bounds.push([trip.lat, trip.lng]);
				}

				if (bounds.length > 0) {
					map.fitBounds(bounds, {
						padding: [45, 45],
						maxZoom: 3.75,
					});
				}

				window.addEventListener("resize", () => map.invalidateSize());
			} catch (error) {
				console.error("Failed to initialize map", error);
				mapEl.innerHTML =
					"<p style='padding:1rem;color:#3f4e3e'>Could not load map. Please refresh or check your network connection.</p>";
			}
		</script>
